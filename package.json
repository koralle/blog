{
  "name": "blog",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "remix vite:build",
    "dev": "remix vite:dev",
    "start": "wrangler pages dev ./build/client",
    "typecheck": "tsc",
    "pages:deploy": "pnpm run build && wrangler pages deploy ./build/client",
    "test": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "biome lint .",
    "format": "biome format . --write",
    "check": "biome check .",
    "fix": "biome check . --apply"
  },
  "dependencies": {
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-icons": "^1.3.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@remix-run/cloudflare": "^2.10.0",
    "@remix-run/cloudflare-pages": "^2.10.0",
    "@remix-run/css-bundle": "^2.10.0",
    "@remix-run/react": "^2.10.0",
    "@vanilla-extract/css": "^1.15.3",
    "@vanilla-extract/sprinkles": "^1.6.2",
    "clsx": "^2.1.1",
    "dedent": "1.5.3",
    "highlight.js": "^11.9.0",
    "hono": "^4.4.10",
    "html-react-parser": "^5.1.10",
    "isbot": "^5.1.11",
    "microcms-js-sdk": "^3.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remix-hono": "^0.0.16",
    "the-new-css-reset": "^1.11.2",
    "valibot": "^0.35.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.8.3",
    "@cloudflare/workers-types": "^4.20240620.0",
    "@remix-run/dev": "^2.10.0",
    "@remix-run/eslint-config": "^2.10.0",
    "@remix-run/testing": "^2.10.0",
    "@storybook/addon-essentials": "^7.6.20",
    "@storybook/addon-interactions": "^7.6.20",
    "@storybook/addon-links": "^7.6.20",
    "@storybook/addon-onboarding": "^1.0.11",
    "@storybook/blocks": "^7.6.20",
    "@storybook/react": "^7.6.20",
    "@storybook/react-vite": "^7.6.20",
    "@storybook/test": "^7.6.20",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vanilla-extract/vite-plugin": "^4.0.12",
    "msw": "^2.3.1",
    "storybook": "^7.6.20",
    "typescript": "^5.5.3",
    "vite": "^5.3.2",
    "vite-tsconfig-paths": "4.3.2",
    "vitest": "^1.6.0",
    "wrangler": "3.62.0"
  }
}
